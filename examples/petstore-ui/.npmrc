# @fromforgesoftware packages (ts-kit / vue-kit) are published to GitHub
# Packages, not the public npm registry. Scope only that org there and
# authenticate with a GitHub token, e.g.:
#
#   NODE_AUTH_TOKEN=$(gh auth token) npm install
#
# Everything else still resolves from the default public registry.
@fromforgesoftware:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
